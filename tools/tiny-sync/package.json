{
  "name": "kropfeet-tiny-sync",
  "version": "0.1.0",
  "private": true,
  "description": "Utilitário Node de sincronização Tiny ERP → Supabase do KroopFeet CRM (uso esporádico).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "sync:tiny": "tsx scripts/sincronizar-tiny.ts",
    "sync:tiny:pagina": "tsx scripts/sincronizar-pagina.ts",
    "sync:tiny:produto": "tsx scripts/sincronizar-produto.ts",
    "sync:tiny:fornecedores": "tsx scripts/sincronizar-fornecedores.ts",
    "backfill:imagens": "tsx scripts/backfill-imagens.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
