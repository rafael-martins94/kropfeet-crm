# ============================================================
# Supabase - USAR SEMPRE A SERVICE ROLE KEY (server-side only)
# Nunca comitar este arquivo com valores reais.
# ============================================================
SUPABASE_URL=https://ladpawjpnaydgqremtnu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque_aqui_a_service_role_key
# Nome do bucket no Supabase Storage onde ficam as imagens dos modelos.
SUPABASE_BUCKET_IMAGENS=imagens-modelos

# ============================================================
# Tiny ERP API v2
# Token obtido em: Configuracoes > Integracoes > API > Gerar Token
# ============================================================
TINY_API_TOKEN=coloque_aqui_o_token_do_tiny
TINY_API_BASE_URL=https://api.tiny.com.br/api2

# ============================================================
# Controle de execucao da sincronizacao
# ============================================================
# Delay em ms entre requisicoes ao Tiny (evita rate limit - 30 req/min).
TINY_DELAY_MS=2200
# Tentativas por requisicao em erro temporario (API bloqueada usa espera maior entre elas).
TINY_MAX_RETRIES=8
# Espera entre retentativas quando a Tiny retorna codigo 6 (API bloqueada) ou 30 (limite).
TINY_ESPERA_API_BLOQUEADA_MS=60000
TINY_ESPERA_API_BLOQUEADA_MAX_MS=180000
# Timeout por requisicao (ms).
TINY_TIMEOUT_MS=30000
# Quando true, ao sincronizar um produto enriquece o fornecedor vinculado com o
# payload completo do endpoint /contato.obter.php (1 chamada extra por
# fornecedor novo). Quando false, so grava nome + id_tiny do fornecedor.
TINY_ENRIQUECER_FORNECEDOR=true

# ============================================================
# Storage de imagens dos modelos
# ============================================================
# Quando true, baixa cada imagem do Tiny e faz upload no bucket do Supabase.
# Quando false, grava apenas url_origem (modo degradado, util em dev).
STORAGE_IMAGENS_HABILITADO=true
STORAGE_IMAGENS_TIMEOUT_MS=20000
STORAGE_IMAGENS_MAX_RETRIES=2
# Limite por arquivo (deve bater com o file_size_limit configurado no bucket).
STORAGE_IMAGENS_TAMANHO_MAXIMO_BYTES=10485760
